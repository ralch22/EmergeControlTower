# Emerge Digital Control Tower - Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# DATABASE (Auto-configured by Replit)
# ===========================================
DATABASE_URL=postgresql://...

# ===========================================
# AI PROVIDERS (Via Replit AI Integrations)
# ===========================================
# These are auto-configured when you add the Anthropic integration:
# AI_INTEGRATIONS_ANTHROPIC_BASE_URL=...
# AI_INTEGRATIONS_ANTHROPIC_API_KEY=...

# ===========================================
# ADDITIONAL AI PROVIDERS
# ===========================================

# Google Gemini - Fast AI for topic generation
# Get your key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ElevenLabs - AI Voice Generation
# Get your key at: https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Runway ML - AI Video Generation
# Get your key at: https://runwayml.com
RUNWAY_API_KEY=your_runway_api_key_here

# Pika Labs - Alternative AI Video Generation
# Get your key at: https://pika.art
PIKA_API_KEY=your_pika_api_key_here

# Midjourney - AI Image Generation (via API proxy)
# Requires Midjourney subscription
MIDJOURNEY_API_KEY=your_midjourney_api_key_here

# Flux - AI Image Generation
# Get your key at: https://bfl.ml
FLUX_API_KEY=your_flux_api_key_here

# Replicate - Alternative AI Image/Video
# Get your key at: https://replicate.com
REPLICATE_API_KEY=your_replicate_api_key_here

# ===========================================
# INTEGRATIONS
# ===========================================

# Slack - Approval Notifications with Action Buttons
# Create a Slack app and get webhook URL at: https://api.slack.com/apps
# The webhook should be an Incoming Webhook with interactive messages enabled
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Buffer - Auto-Publishing to Social Media
# Get your access token at: https://buffer.com/developers
# Requires connected social profiles in Buffer
BUFFER_ACCESS_TOKEN=your_buffer_access_token_here

# ===========================================
# OBJECT STORAGE — Cloudflare R2 (PR 1.6)
# ===========================================
# Brand asset uploads (and any future binary blobs) persist to R2 instead of
# container-local disk. Required for any deploy outside Replit — without R2,
# upload endpoints return 500. Get the credentials at
# Cloudflare dashboard > R2 > Manage R2 API tokens.
R2_ACCOUNT_ID=your_cloudflare_account_id_here
R2_BUCKET=emerge-control-tower-assets
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
# Optional. If the bucket is fronted by a Cloudflare custom domain
# (e.g. https://assets.emerge.digital), download URLs use it directly
# (unsigned, CDN-cacheable). Otherwise we generate signed URLs that
# expire after 1 hour. Leave unset if you haven't wired a custom domain.
# R2_PUBLIC_BASE_URL=https://assets.emerge.digital

# ===========================================
# APPLICATION
# ===========================================
NODE_ENV=development
PORT=5000

# Content Factory Python Service
CONTENT_FACTORY_PORT=8000
CONTENT_FACTORY_URL=http://localhost:8000

# Dashboard URL (for Python service to push updates)
DASHBOARD_URL=http://localhost:5000
APP_BASE_URL=http://localhost:5000

# ===========================================
# PRODUCTION DEPLOYMENT
# ===========================================
# For Google Cloud Vertex / Render deployment, set these:
# PROJECT_ID=your-gcp-project-id
# REGION=us-central1
